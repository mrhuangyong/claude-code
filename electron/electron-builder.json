{
  "appId": "com.claude-code-best.app",
  "productName": "Claude Code Best",
  "copyright": "Copyright © 2026 claude-code-best",
  "directories": {
    "output": "electron/dist"
  },
  "files": [
    "electron/src/main.js",
    "electron/src/preload.js",
    "electron/src/assets/**/*",
    "dist/**/*"
  ],
  "mac": {
    "category": "public.app-category.developer-tools",
    "icon": "electron/src/assets/icon.svg"
  },
  "win": {
    "target": [
      "nsis",
      "portable"
    ],
    "icon": "electron/src/assets/icon.svg"
  },
  "linux": {
    "target": [
      "deb",
      "rpm",
      "AppImage"
    ],
    "icon": "electron/src/assets/icon.svg"
  }
}